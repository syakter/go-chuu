# Last.fm API credentials (required)
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_API_SECRET=your_lastfm_api_secret_here

# Platform Configuration
ENABLE_SLACK=true
ENABLE_DISCORD=false

# Slack Configuration (required if ENABLE_SLACK=true)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_APP_TOKEN=xapp-your-slack-app-token-here
SLACK_CHANNEL_ID=C0392543PUY

# Discord Configuration (required if ENABLE_DISCORD=true)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here

# Optional Configuration
LOG_LEVEL=info
MAX_CONCURRENT_REQUESTS=10
CACHE_ENABLED=true
CACHE_TTL=5m
REQUEST_TIMEOUT=30s
SHUTDOWN_TIMEOUT=30s

# User List (comma-separated Last.fm usernames)
# Leave empty to use default list
USERS=
